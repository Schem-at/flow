# Flow client (Vite) env. Copy to `.env.local` for local overrides.
#
# Defaults (no env set) target LOCAL STANDALONE dev:
#   - HMR over ws://localhost
#   - /api proxied to the local Hono server at http://localhost:3001
#
# These defaults make plain `bun run dev` work on your machine without Docker.

# Dev server port (must match the Hono CORS / proxy expectations)
VITE_PORT=5176

# Backend base URL used by the client API module (empty = same-origin via Vite proxy)
VITE_SERVER_URL=

# Schemati origin for auth/profile links (coupled mode). Harmless when auth is off.
VITE_SCHEMATI_URL=https://schemati.test

# --- Vite HMR + /api proxy (env-driven; local defaults shown) ---
VITE_HMR_HOST=localhost
VITE_HMR_PROTOCOL=ws
VITE_API_PROXY_TARGET=http://localhost:3001

# ============================================================================
# COUPLED MODE (running inside schemati's Docker network) — set these in
# schemati's docker-compose env for the flow container, NOT here:
#
#   VITE_HMR_HOST=flow.schemati.test
#   VITE_HMR_PROTOCOL=wss
#   VITE_API_PROXY_TARGET=http://schemati-app:80
# ============================================================================
